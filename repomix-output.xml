                    <p className="text-[#888] text-xs">{op.vehicle}</p>
                  </div>
                  {op.etaAirport !== '—' && (
                    <div className="ml-auto text-right">
                      <p className="text-[#888] text-xs">ETA airport</p>
                      <p className="text-[#BA7517] font-semibold text-sm">{op.etaAirport}</p>
                    </div>
                  )}
                </div>
              )}

              {op.status === 'unassigned' && (
