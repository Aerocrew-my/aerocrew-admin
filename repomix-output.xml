  const totalCommission = payouts.reduce((s, p) => s + p.commission, 0)
  const totalNet = payouts.reduce((s, p) => s + p.net, 0)
  const pendingAmount = payouts.filter(p => p.status === 'pending').reduce((s, p) => s + p.net, 0)

  const markPaid = (id: string) => {
